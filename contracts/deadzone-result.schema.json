{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deadzone.local/contracts/deadzone-result.schema.json",
  "title": "DeadZone build result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "request_id",
    "project",
    "status",
    "provider",
    "url",
    "file_name",
    "sha256",
    "size",
    "completed_at"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "request_id": { "type": "string", "pattern": "^DZ-[A-Z]{2}-[0-9]{8}-[0-9]{4}$" },
    "project": { "enum": ["frameworkpatcher", "gamingplus", "lite"] },
    "status": { "const": "success" },
    "provider": { "const": "google_drive" },
    "url": { "type": "string", "pattern": "^https://(drive|docs)\\.google\\.com/" },
    "file_name": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*\\.zip$" },
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "size": { "type": "integer", "minimum": 1 },
    "os": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._ -]*$" },
    "codename": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" },
    "completed_at": { "type": "string", "format": "date-time" },
    "android_version": { "type": "string" },
    "device_name": { "type": "string" },
    "rom_version": { "type": "string" },
    "features": { "type": "array", "uniqueItems": true, "items": { "type": "string" } }
  },
  "oneOf": [
    {
      "properties": { "project": { "enum": ["gamingplus", "lite"] } },
      "required": ["os", "codename"]
    },
    {
      "properties": { "project": { "const": "frameworkpatcher" } },
      "required": ["android_version", "device_name", "rom_version", "features"]
    }
  ]
}
